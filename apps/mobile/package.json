    "expo": "~50.0.0",
    "expo-router": "~3.4.0",
    "expo-status-bar": "~1.11.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@booking-app/config": "workspace:*",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3"
  }
