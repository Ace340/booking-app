{
  "name": "@booking-app/config",
  "version": "1.0.0",
  "private": true,
  "exports": {
    "./tsconfig/base.json": "./tsconfig/base.json"
  },
  "files": [
    "eslint",
    "prettier",
    "tsconfig"
