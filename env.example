# ─── Application ───────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=v1
LOG_LEVEL=log

# ─── Database ──────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/booking_app"

# ─── Auth (Clerk) ─────────────────────────────────
# Get these from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWT_KEY=                          # Optional: for local JWT verification
CLERK_WEBHOOK_SECRET=whsec_xxx          # From Clerk Dashboard → Webhooks
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,exp://192.168.*.*:19000

# ─── CORS ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,exp://192.168.*.*:19000

# ─── Stripe (Payment) ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Web (client-side) ────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ─── Mobile ────────────────────────────────────────
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
